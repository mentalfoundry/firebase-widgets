{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*"],
    "headers": [
      {
        "source": "/counter/**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "frame-ancestors *"
          }
        ]
      },
      {
        "source": "/chat/**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "frame-ancestors *"
          }
        ]
      },
      {
        "source": "/news/**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "frame-ancestors *"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
